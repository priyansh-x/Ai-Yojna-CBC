{
  "scheme_id": "pmay_urban",
  "scheme_name": "Pradhan Mantri Awaas Yojana — Urban (PMAY-U)",
  "ministry": "Ministry of Housing & Urban Affairs",
  "benefit": "Subsidy on home loan interest: EWS/LIG — 6.5% interest subsidy on ₹6L loan; MIG-I — 4% on ₹9L; MIG-II — 3% on ₹12L. OR direct construction grant for EWS (₹1.5L) under BLC component",
  "application_portal": "pmaymis.gov.in",
  "source_urls": [
    "https://pmaymis.gov.in",
    "https://mohua.gov.in/upload/uploadfiles/files/PMAY_U_Guidelines.pdf"
  ],
  "last_verified": "2026-04-11",
  "source_confidence": 0.87,
  "notes": "PMAY-U has 4 components: CLSS (credit linked subsidy), AHP (affordable housing), BLC (beneficiary-led), ISS (in-situ slum redevelopment). Income slab determines component eligibility.",

  "eligibility_rules": {
    "operator": "AND",
    "conditions": [
      {
        "rule_id": "pmayu_r1",
        "field": "residence_type",
        "operator": "IN",
