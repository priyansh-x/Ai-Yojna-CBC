              {
                "rule_id": "pmk_excl_5",
                "field": "is_pension_recipient_above_10k",
                "operator": "EQ",
                "value": true,
                "confidence": 0.85,
                "source": "Exclusion criterion (v) — retired pensioners with monthly pension ≥ ₹10,000"
              },
              {
                "rule_id": "pmk_excl_6",
                "field": "is_doctor_lawyer_engineer_ca",
                "operator": "EQ",
                "value": true,
