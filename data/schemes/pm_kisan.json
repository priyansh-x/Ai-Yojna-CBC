  "eligibility_rules": {
    "operator": "AND",
    "conditions": [
      {
        "rule_id": "pmk_r1",
        "description": "Must be a farmer/cultivator family owning cultivable land",
        "operator": "AND",
        "conditions": [
          {
            "rule_id": "pmk_r1a",
            "field": "occupation",
            "operator": "IN",
            "value": ["farmer", "cultivator", "agricultural_landowner"],
            "confidence": 0.95,
            "source": "PM-KISAN Operational Guidelines 2019, Section 2.1 — 'farmer families having cultivable land'"
          },
          {
            "rule_id": "pmk_r1b",
            "field": "land_ownership",
            "operator": "EQ",
            "value": true,
            "confidence": 0.80,
            "source": "PM-KISAN Operational Guidelines 2019 — 'land holding in their names'",
            "ambiguity_flag": "AMBIGUITY-003",
            "ambiguity_note": "Leased/sharecrop land not explicitly excluded but 'in their names' implies formal ownership. Field offices apply this inconsistently."
          }
        ]
      },
      {
        "rule_id": "pmk_r2",
        "description": "Must NOT fall under any exclusion category",
        "operator": "NOT",
        "conditions": [
          {
            "operator": "OR",
            "conditions": [
              {
                "rule_id": "pmk_excl_1",
                "field": "is_income_tax_payer",
                "operator": "EQ",
                "value": true,
                "confidence": 0.90,
                "source": "Exclusion criterion (i) — 'All Institutional Land holders'",
                "ambiguity_flag": "AMBIGUITY-011",
                "ambiguity_note": "Household-level or individual-level? If a son files ITR but the farmer does not, the farmer's status is contested."
              },
              {
                "rule_id": "pmk_excl_2",
                "field": "is_institutional_land_holder",
                "operator": "EQ",
                "value": true,
                "confidence": 0.95,
                "source": "Exclusion criterion (ii) — institutional land holders (trusts, societies, etc.)"
              },
              {
                "rule_id": "pmk_excl_3",
                "field": "is_constitutional_post_holder",
                "operator": "EQ",
                "value": true,
                "confidence": 0.95,
                "source": "Exclusion criterion (iii) — former/current holders of constitutional posts (President, VP, CM, etc.)"
              },
              {
                "rule_id": "pmk_excl_4",
                "field": "is_current_former_government_employee",
                "operator": "EQ",
                "value": true,
                "confidence": 0.90,
