    {"document": "Age Proof (birth cert / school cert / voter ID)", "mandatory": true, "priority": 3, "obtainable_from": "Municipality / School / Election Commission"},
    {"document": "Bank Account", "mandatory": true, "priority": 4, "obtainable_from": "Any bank / PMJDY"},
    {"document": "Disability Certificate (for IGNDPS)", "mandatory": false, "priority": 5, "obtainable_from": "District Civil Surgeon / Medical Board"},
    {"document": "Husband's Death Certificate (for IGNWPS)", "mandatory": false, "priority": 5, "obtainable_from": "Municipality / Gram Panchayat"}
