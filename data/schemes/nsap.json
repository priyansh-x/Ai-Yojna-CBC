{
  "scheme_id": "nsap",
  "scheme_name": "National Social Assistance Programme (NSAP)",
  "ministry": "Ministry of Rural Development",
  "benefit": "Monthly pension: IGNOAPS (old age) ₹200–₹500/month; IGNWPS (widow) ₹300/month; IGNDPS (disability) ₹300/month; NFBS (family bereavement) ₹20,000 one-time",
  "application_portal": "nsap.nic.in",
  "source_urls": [
    "https://nsap.nic.in",
